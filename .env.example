SLM_BACKEND=local
EXPERT_EXECUTION_MODE=slm
TEAM3_REQUIRE_LOCAL_SLM=false
TARGET_TIMEOUT_SEC=60
TARGET_MAX_PROMPTS=6

# Optional local SLM mode when SLM_BACKEND=local: http | hf
LOCAL_SLM_MODE=hf

# Optional local/remote LLM proxy for expert execution (LOCAL_SLM_MODE=http)
LOCAL_SLM_ENDPOINT=http://127.0.0.1:9000/v1/complete-json
LOCAL_SLM_TIMEOUT_SEC=60
LOCAL_SLM_API_KEY=

# Optional in-process open-weight backend (requires SLM_BACKEND=local and LOCAL_SLM_MODE=hf)
LOCAL_HF_MODEL_ID=Qwen/Qwen3.5-4B
LOCAL_HF_DEVICE=auto
LOCAL_HF_DTYPE=auto
LOCAL_HF_MAX_INPUT_CHARS=12000
LOCAL_HF_MAX_NEW_TOKENS=448
LOCAL_HF_TEMPERATURE=0.1
LOCAL_HF_TOP_P=0.9

# Optional target-model execution path
TARGET_ENDPOINT=
TARGET_MODEL=
TARGET_API_KEY=

# Optional external integrations (disabled by default for grading)
INSPECT_ENABLED=false
GARAK_ENABLED=false
